# Copiá este archivo como .env y completá los valores.

# MongoDB local: mongodb://127.0.0.1:27017/voltx
# MongoDB Atlas: mongodb+srv://usuario:password@cluster.mongodb.net/voltx
MONGODB_URI=mongodb://127.0.0.1:27017/voltx

PORT=4000

# Origen permitido por CORS (la URL del frontend en desarrollo)
CLIENT_ORIGIN=http://localhost:5173

# Cualquier string largo y secreto sirve. Generá uno propio para producción.
JWT_SECRET=cambiame-por-un-secreto-largo-y-random
JWT_EXPIRES_IN=7d

# SMTP opcional: si lo dejás vacío, el server igual funciona pero no manda
# el mail de confirmación de orden (solo lo deja registrado en la consola).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
