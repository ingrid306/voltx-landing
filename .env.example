# Copiá este archivo como .env y completá con tus credenciales de EmailJS
# (https://www.emailjs.com/) para que el formulario de contacto envíe
# mails reales. Si lo dejás vacío, el formulario sigue funcionando y
# validando correctamente, pero el envío se simula (modo demo).

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# URL del backend (Express)
VITE_API_URL=http://localhost:4000
